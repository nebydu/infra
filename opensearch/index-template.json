{
  "index_patterns": ["app-*"],
  "priority": 1,
  "template": {
    "settings": {
      "index.number_of_shards": 1,
      "index.number_of_replicas": 0,
      "index.plugins.index_state_management.policy_id": "general-retention",
      "index.plugins.index_state_management.rollover_alias": "app"
    },
    "mappings": {
      "dynamic": true
    }
  }
}
