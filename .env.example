# T1-1 데이터스토어 4종 환경변수 템플릿 — phase1-050-infra.
#
# 사용법: 이 파일을 .env 로 복사하고 placeholder를 실제 값으로 채운다.
#   cp .env.example .env   (그리고 .env 는 절대 커밋하지 않는다 — .gitignore 처리됨)
#
# ★ 실제 비밀번호를 이 파일(.env.example)에 적지 마라 — placeholder만 둔다 ★
#   compose는 ${VAR:?} 로 빈 값 기동을 실패시키므로 누락 시 즉시 드러난다.
#   향후 운영(Vault/KMS)에서는 동일 변수명으로 시크릿이 주입된다(forward-compatible).

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=appdb
# PG_PORT=5432          # 호스트 포트 충돌 시 override
# PG_BIND=127.0.0.1     # 외부 노출이 필요할 때만 0.0.0.0 등으로 override(주의)

# ── OpenSearch ───────────────────────────────────────────────────────────
# OS_PORT=9200
# OS_BIND=127.0.0.1

# ── Redis (캐시 전용) ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME
# REDIS_MAXMEM=256mb
# REDIS_PORT=6379
# REDIS_BIND=127.0.0.1

# ── MinIO ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME          # 8자 이상 권장(MinIO 요건)
# MINIO_DEFAULT_BUCKET=app-objects     # 중립명 일반 버킷
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MINIO_BIND=127.0.0.1
